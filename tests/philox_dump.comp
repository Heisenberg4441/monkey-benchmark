#version 450
#extension GL_GOOGLE_include_directive : require

// Тестовый шейдер: выгружает index_stream(seed, key, pos) в SSBO для первых
// N входов. Использует тот же src/philox.glsl, что и боевой monkey.comp, поэтому
// сравнение результата с CPU-эталоном (test_vulkan_philox) проверяет реальный
// скомпилированный SPIR-V, а не его C++-транслитерацию.

layout(local_size_x = 256) in;

layout(std430, binding = 0) writeonly buffer OutBuf { uint outv[]; };

layout(push_constant) uniform PC {
    uint seed;
    uint count;
} pc;

#include "philox.glsl"

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.count) return;
    // Тот же маппinг, что в test_glsl_philox: key = i>>4, pos = i&0xF.
    outv[i] = index_stream(pc.seed, i >> 4u, i & 0xFu);
}
