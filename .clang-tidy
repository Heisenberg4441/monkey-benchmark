# Базовый набор проверок: ошибки, читаемость, переносимость, современный C++.
# Отключены проверки, конфликтующие со стилем низкоуровневого compute-кода
# (магические числа констант PRNG, короткие имена в горячих циклах, C-массивы
# в CUDA/GLSL-совместимых структурах).
Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  portability-*,
  readability-*,
  modernize-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -readability-identifier-length,
  -bugprone-easily-swappable-parameters,
  -modernize-avoid-c-arrays,
  -readability-function-cognitive-complexity

WarningsAsErrors: ''
HeaderFilterRegex: 'src/.*\.(h|cpp)$'
FormatStyle: file
